# PyroCast frontend — configuration.
# Copy this file to ".env". The frontend gets live fire data from the PyroCast
# backend (see /backend); without a reachable backend it renders clearly-labeled
# synthetic data.

# PyroCast backend base URL (FastAPI). Default if unset: http://localhost:8000
VITE_API_BASE=http://localhost:8000

# Optional: keys for the legacy browser-direct data path (weather/elevation in
# the Region View still use these until wired to the backend).
# NASA FIRMS map key — free: https://firms.modaps.eosdis.gov/api/map_key/
VITE_FIRMS_KEY=DEMO_KEY
# OpenWeatherMap API key — free: https://home.openweathermap.org/api_keys
VITE_OWM_KEY=DEMO_KEY
