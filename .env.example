# PyroCast — optional live-data API keys.
# Copy this file to ".env" and fill in real keys to switch from the synthetic
# fallback datasets to live data. Without them, the app runs fully on clearly
# labeled simulated data.

# NASA FIRMS map key — free: https://firms.modaps.eosdis.gov/api/map_key/
VITE_FIRMS_KEY=DEMO_KEY

# OpenWeatherMap API key — free: https://home.openweathermap.org/api_keys
VITE_OWM_KEY=DEMO_KEY
